FLASK_ENV=development
SECRET_KEY=mude-esta-chave-para-producao-use-algo-aleatorio-longo

# Seu número do WhatsApp com DDI (sem + nem espaços)
# Exemplo Brasil: 5585999999999
WHATSAPP_NUMBER=5585999999999

# Admin padrão (pode alterar antes de iniciar)
